---
import NavActions from './features/NavActions';
import NotificationsBell from './features/NotificationsBell';
const currentPath = Astro.url.pathname;

const navLinks = [
  { href: '/dashboard',  label: 'Dashboard' },
  { href: '/bookings',   label: 'Reservas' },
  { href: '/expenses',   label: 'Gastos' },
];

const adminLinks = [
  { href: '/properties',    label: 'Propiedades',     desc: 'Inmuebles y datos básicos' },
  { href: '/accounts',      label: 'Cuentas bancarias', desc: 'Bancos, saldos y pagos' },
  { href: '/vendors',       label: 'Servicios y proveedores', desc: 'Facturas mensuales y reparto' },
  { href: '/aseo',          label: 'Aseo',            desc: 'Personal y saldos adeudados' },
];

const adminActive = adminLinks.some(l => currentPath.startsWith(l.href));
---

<nav class="sticky top-0 z-50 border-b border-slate-200 bg-white shadow-sm px-8 py-3 flex justify-between items-center">
  <div class="flex items-center gap-2">
    <div class="w-8 h-8 bg-blue-600 rounded-lg flex items-center justify-center text-white font-bold text-sm shadow-sm">A</div>
    <span class="text-xl font-bold text-slate-800">STR Analytics</span>
  </div>
  <div class="flex items-center gap-6">
    {navLinks.map(link => (
      <a
        href={link.href}
        class={`text-sm font-medium transition-colors ${
          currentPath === link.href
            ? 'text-blue-600 border-b-2 border-blue-500 pb-0.5'
            : 'text-slate-600 hover:text-blue-600'
        }`}
      >
        {link.label}
      </a>
    ))}

    <div class="relative group">
      <button
        class={`text-sm font-medium transition-colors inline-flex items-center gap-1 ${
          adminActive
            ? 'text-blue-600 border-b-2 border-blue-500 pb-0.5'
            : 'text-slate-600 hover:text-blue-600'
        }`}
      >
        Administración
        <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 11.08l3.71-3.85a.75.75 0 011.08 1.04l-4.25 4.4a.75.75 0 01-1.08 0l-4.25-4.4a.75.75 0 01.02-1.06z" clip-rule="evenodd" />
        </svg>
      </button>
      <div class="invisible opacity-0 translate-y-1 group-hover:visible group-hover:opacity-100 group-hover:translate-y-0 transition-all duration-150 absolute right-0 top-full pt-2 w-72 z-50">
        <div class="bg-white rounded-xl shadow-xl border border-slate-200 py-2">
          {adminLinks.map(l => (
            <a
              href={l.href}
              class={`block px-4 py-2.5 hover:bg-slate-50 ${
                currentPath.startsWith(l.href) ? 'bg-blue-50' : ''
              }`}
            >
              <div class={`text-sm font-semibold ${currentPath.startsWith(l.href) ? 'text-blue-700' : 'text-slate-800'}`}>
                {l.label}
              </div>
              <div class="text-xs text-slate-500">{l.desc}</div>
            </a>
          ))}
        </div>
      </div>
    </div>

    <NotificationsBell client:load />
    <NavActions client:load />
  </div>
</nav>
